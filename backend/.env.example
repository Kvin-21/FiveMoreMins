# EmailJS settings (get these from https://www.emailjs.com/)
EMAILJS_SERVICE_ID=your_service_id
EMAILJS_TEMPLATE_ID=your_template_id
EMAILJS_PUBLIC_KEY=your_public_key
EMAILJS_PRIVATE_KEY=your_private_key

# Alternative: use Gmail via nodemailer (comment out EmailJS above if using this)
# EMAIL_METHOD=nodemailer
# GMAIL_USER=your.email@gmail.com
# GMAIL_APP_PASSWORD=your_16_char_app_password

# Server port
PORT=3001

# Session secret - change this to something random
SESSION_SECRET=change_me_please_use_something_random_here
